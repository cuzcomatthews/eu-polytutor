# ============================================
# PolyTutor - Environment Variables
# Copy to .env and fill in values
# ============================================

# --- Database (any PostgreSQL with pgvector) ---
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# --- APIs (required) ---
DEEPGRAM_API_KEY=
DEEPSEEK_API_KEY=
HUGGINGFACEHUB_API_TOKEN=

# --- TTS Voices (Deepgram Aura) ---
# Example German voices shown below. Use any language-compatible voice.
# Find voices at: https://developers.deepgram.com/docs/tts-models
DEEPGRAM_TTS_VOICE_PROFESSOR=aura-2-fabian-de
DEEPGRAM_TTS_VOICE_TUTOR=aura-2-julius-de
DEEPGRAM_TTS_VOICE_COMPANION_M=aura-2-julius-de
DEEPGRAM_TTS_VOICE_COMPANION_F=aura-2-lara-de

# --- Language Configuration ---
# The target language the user is learning (e.g., "de", "fr", "it", "ja")
TARGET_LANGUAGE=de
# The user's native language for explanations (e.g., "es", "en", "fr")
NATIVE_LANGUAGE=es

# --- RAG Configuration ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.3
RAG_REQUIRE_CONTEXT=false
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=300

# --- LLM Configuration ---
LLM_MAX_CONVERSATION_TOKENS=256
LLM_MAX_TEACHING_TOKENS=768
LLM_MAX_SYLLABUS_TOKENS=4096

# --- Memory ---
MEMORY_MAX_TURNS=16
MEMORY_SUMMARY_TRIGGER=24
