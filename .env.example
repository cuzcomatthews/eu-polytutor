# ============================================
# EU PolyTutor - Environment Variables
# Copy to .env and fill in values
# ============================================

# --- Database (Neon) ---
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# --- APIs ---
DEEPGRAM_API_KEY=
DEEPSEEK_API_KEY=
HUGGINGFACEHUB_API_TOKEN=

# --- TTS Voices (Deepgram Aura) ---
# Fill with your preferred voice codes for the target language
DEEPGRAM_TTS_VOICE_PROFESSOR=
DEEPGRAM_TTS_VOICE_TUTOR=
DEEPGRAM_TTS_VOICE_COMPANION_M=
DEEPGRAM_TTS_VOICE_COMPANION_F=

# --- Language Configuration ---
# The target language the user is learning (e.g., "de", "fr", "it")
TARGET_LANGUAGE=de
# The user's native language for explanations (e.g., "es", "en")
NATIVE_LANGUAGE=es

# --- RAG Configuration ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=300

# --- LLM Configuration ---
LLM_MAX_CONVERSATION_TOKENS=256
LLM_MAX_TEACHING_TOKENS=768
LLM_MAX_SYLLABUS_TOKENS=4096

# --- Memory ---
MEMORY_MAX_TURNS=16
MEMORY_SUMMARY_TRIGGER=24

# --- Cache ---
CACHE_ENABLED=true
CACHE_TTL_DAYS=30
